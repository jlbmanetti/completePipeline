# Copy this file to .env and fill in the values. Never commit .env (it is in .gitignore).
# ----- AWS (required for the upload script: local → S3) -----
# You do NOT need to do anything else in the AWS Console after creating the bucket.
# Create keys: IAM → Users → your user → Security credentials → Create access key.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2

# ----- Optional: defaults for the upload script -----
S3_BUCKET=completepipeline-raw
S3_PREFIX=raw/olist

# ----- Snowflake (for later: Airbyte destination, DBT, ML) -----
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=

# ----- Airbyte (for later: Airflow connection to trigger syncs) -----
# AIRBYTE_API_HOST=http://localhost:8000
# AIRBYTE_CLIENT_ID=
# AIRBYTE_CLIENT_SECRET=
